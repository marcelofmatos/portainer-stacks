# Variáveis para subir a stack "socat".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Porta de escuta — Porta que o socat escuta e publica no no (ex.: 3306) [OBRIGATÓRIA]
SOCAT_LISTEN_PORT=

# Destino (host:porta) — Ex.: mariadb:3306 [OBRIGATÓRIA]
SOCAT_TARGET=

# ─────────── Opcionais (defaults abaixo) ───────────
# Tag da imagem
SOCAT_IMAGE_TAG=latest

# Variáveis para subir a stack "phpnetmap".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: netmap.exemplo.com [OBRIGATÓRIA]
PHPNETMAP_FQDN=

# Senha do admin — Senha do usuario admin (segredo) [OBRIGATÓRIA]
PHPNETMAP_ADMIN_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Usuario admin
PHPNETMAP_ADMIN_USER=admin

# Tag da imagem
PHPNETMAP_IMAGE_TAG=latest

# Variáveis para subir a stack "joomla".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: joomla.exemplo.com [OBRIGATÓRIA]
JOOMLA_FQDN=

# Senha do banco — Senha do usuario do banco [OBRIGATÓRIA]
JOOMLA_DB_PASSWORD=

# Senha root MySQL — Senha root do MySQL [OBRIGATÓRIA]
MYSQL_ROOT_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Rede do proxy
PROXY_NET=web

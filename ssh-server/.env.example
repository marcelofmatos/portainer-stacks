# Variáveis para subir a stack "ssh-server".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Chave publica SSH — Conteudo da sua id_*.pub (login por chave) [OBRIGATÓRIA]
SSH_PUBLIC_KEY=

# ─────────── Opcionais (defaults abaixo) ───────────
# Usuario
SSH_USER=sftp

# Porta SSH
SSH_PORT=2222

# Permitir senha
SSH_PASSWORD_ACCESS=false

# Conceder sudo
SSH_SUDO_ACCESS=false

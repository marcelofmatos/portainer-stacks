# Variáveis para subir a stack "wordpress".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: blog.exemplo.com [OBRIGATÓRIA]
WORDPRESS_FQDN=

# Senha do banco — Senha do usuario do banco (app e db) [OBRIGATÓRIA]
WORDPRESS_DB_PASSWORD=

# Senha root do banco — Senha root do MariaDB embarcado [OBRIGATÓRIA]
WORDPRESS_DB_ROOT_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Host do banco
WORDPRESS_DB_HOST=db

# Banco
WORDPRESS_DB_NAME=wordpress

# Usuario do banco
WORDPRESS_DB_USER=wordpress

# Rede do proxy
PROXY_NET=web

# Rede de dados
DATA_NET=data

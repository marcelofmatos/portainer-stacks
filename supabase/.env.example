# Variáveis para subir a stack "supabase".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio do Studio — Ex.: studio.exemplo.com [OBRIGATÓRIA]
SUPABASE_STUDIO_FQDN=

# Dominio da API — Ex.: api.exemplo.com [OBRIGATÓRIA]
SUPABASE_API_FQDN=

# Senha do Postgres — Usada por todos os servicos [OBRIGATÓRIA]
POSTGRES_PASSWORD=

# JWT secret — Segredo HS256 (min. 32 chars) [OBRIGATÓRIA]
JWT_SECRET=

# Anon key — JWT da role anon [OBRIGATÓRIA]
ANON_KEY=

# Service role key — JWT da role service_role [OBRIGATÓRIA]
SERVICE_ROLE_KEY=

# Usuario do Studio — Basic-auth do Studio [OBRIGATÓRIA]
DASHBOARD_USERNAME=

# Senha do Studio — Basic-auth do Studio [OBRIGATÓRIA]
DASHBOARD_PASSWORD=

# Realtime key base — Chave de sessao do realtime (64 chars) [OBRIGATÓRIA]
SECRET_KEY_BASE=

# Vault enc key — Chave do Vault (32 chars) [OBRIGATÓRIA]
VAULT_ENC_KEY=

# Logflare API key — Chave do analytics/vector [OBRIGATÓRIA]
LOGFLARE_API_KEY=

# ─────────── Opcionais (defaults abaixo) ───────────
# Rede do proxy
PROXY_NET=web

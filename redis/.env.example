# Variáveis para subir a stack "redis".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Senha (recomendada) — AUTH do Redis; vazio = sem senha [OBRIGATÓRIA]
REDIS_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Limite de memoria
REDIS_MAXMEMORY=256mb

# Politica de eviccao
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Persistencia AOF
REDIS_APPENDONLY=yes

# Rede de dados
DATA_NET=data

# Variáveis para subir a stack "lldap".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio da UI — Ex.: lldap.exemplo.com [OBRIGATÓRIA]
LLDAP_FQDN=

# JWT secret — openssl rand -hex 32 [OBRIGATÓRIA]
LLDAP_JWT_SECRET=

# Key seed — openssl rand -hex 32 (deriva a chave privada; nao troque apos criar dados) [OBRIGATÓRIA]
LLDAP_KEY_SEED=

# Senha do admin — Senha do usuario administrador [OBRIGATÓRIA]
LLDAP_ADMIN_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Base DN — Ex.: dc=exemplo,dc=com
LLDAP_BASE_DN=dc=example,dc=com

# Usuario admin
LLDAP_ADMIN_USERNAME=admin

# Rede do proxy
PROXY_NET=web

# Rede compartilhada LDAP
LDAP_NET=ldap

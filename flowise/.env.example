# Variáveis para subir a stack "flowise".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: flowise.exemplo.com [OBRIGATÓRIA]
FLOWISE_FQDN=

# Senha de login — Senha da UI (segredo) [OBRIGATÓRIA]
FLOWISE_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Usuario de login
FLOWISE_USERNAME=admin

# Tag da imagem
FLOWISE_IMAGE_TAG=latest

# Variáveis para subir a stack "ragflow".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: ragflow.exemplo.com [OBRIGATÓRIA]
RAGFLOW_FQDN=

# Senha do MySQL/MariaDB — Segredo [OBRIGATÓRIA]
RAGFLOW_MYSQL_PASSWORD=

# Senha do MinIO — Segredo [OBRIGATÓRIA]
RAGFLOW_MINIO_PASSWORD=

# Senha do Elasticsearch — Usuario elastic (segredo) [OBRIGATÓRIA]
RAGFLOW_ES_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Usuario do MinIO
RAGFLOW_MINIO_USER=ragflow

# Tag da imagem
RAGFLOW_IMAGE_TAG=latest

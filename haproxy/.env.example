# Variáveis para subir a stack "haproxy".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio das stats (FQDN) — Ex.: haproxy.exemplo.com [OBRIGATÓRIA]
HAPROXY_FQDN=

# Basicauth do Traefik — Formato usuario:hash_bcrypt (htpasswd -nbB) [OBRIGATÓRIA]
HAPROXY_AUTH_BASIC=

# ─────────── Opcionais (defaults abaixo) ───────────
# Nome do Docker config
HAPROXY_CONFIG_NAME=haproxy_config_v1

# Tag da imagem
HAPROXY_IMAGE_TAG=lts-alpine

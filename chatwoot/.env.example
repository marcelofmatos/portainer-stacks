# Variáveis para subir a stack "chatwoot".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: chat.exemplo.com [OBRIGATÓRIA]
CHATWOOT_FQDN=

# Secret key base — Chave de sessao Rails (openssl rand -hex 64) [OBRIGATÓRIA]
CHATWOOT_SECRET_KEY_BASE=

# Senha do PostgreSQL — Senha do usuario do banco (segredo) [OBRIGATÓRIA]
CHATWOOT_DB_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Host do PostgreSQL — Servico de banco embarcado nesta stack (deixe 'db'). So altere para usar um Postgres externo.
CHATWOOT_DB_HOST=db

# Banco
CHATWOOT_DB_NAME=chatwoot

# Usuario do PostgreSQL
CHATWOOT_DB_USER=postgres

# URI do Redis
CHATWOOT_REDIS_URL=redis://redis:6379

# Permitir auto-cadastro
CHATWOOT_ENABLE_SIGNUP=false

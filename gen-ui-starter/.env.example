# Variáveis para subir a stack "gen-ui-starter". Copie para .env: cp .env.example .env

# Domínio (FQDN) onde a UI fica exposta. Ex.: gen-ui.exemplo.com [OBRIGATÓRIA]
GENUI_FQDN=
# Chave OpenAI usada pelo agente LangGraph (https://platform.openai.com/api-keys) [OBRIGATÓRIA]
OPENAI_API_KEY=
# Tag da imagem no GHCR
GENUI_IMAGE_TAG=latest
# Rede externa do proxy (standalone: crie com "docker network create web")
PROXY_NET=web

# Variáveis para subir a stack "litellm".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: llm.exemplo.com [OBRIGATÓRIA]
LITELLM_FQDN=

# Master key — Chave mestra (sk-...) [OBRIGATÓRIA]
LITELLM_MASTER_KEY=

# Salt key — Salt de criptografia (nao alterar depois) [OBRIGATÓRIA]
LITELLM_SALT_KEY=

# OpenAI API key (opcional) — Usada pelo config.yaml [OBRIGATÓRIA]
OPENAI_API_KEY=

# ─────────── Opcionais (defaults abaixo) ───────────
# Docker config
LITELLM_CONFIG_NAME=litellm_config_v1

# Rede do proxy
PROXY_NET=web

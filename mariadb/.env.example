# Variáveis para subir a stack "mariadb".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Senha root — Senha do usuario root [OBRIGATÓRIA]
MARIADB_ROOT_PASSWORD=

# Senha do app — Senha do usuario de aplicacao [OBRIGATÓRIA]
MARIADB_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Banco inicial
MARIADB_DATABASE=appdb

# Usuario do app
MARIADB_USER=app

# Rede de dados
DATA_NET=data

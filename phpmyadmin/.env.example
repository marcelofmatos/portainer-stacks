# Variáveis para subir a stack "phpmyadmin".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: pma.exemplo.com [OBRIGATÓRIA]
PMA_FQDN=

# ─────────── Opcionais (defaults abaixo) ───────────
# Hosts de banco
PMA_HOSTS=mariadb

# Limite de upload
PMA_UPLOAD_LIMIT=256M

# Rede do proxy
PROXY_NET=web

# Rede de dados
DATA_NET=data

# Variáveis para subir a stack "orquestrator4proxmox". Copie para .env: cp .env.example .env
# Domínio público (FQDN) atendido pelo Traefik — ex.: painel.exemplo.com [OBRIGATÓRIA]
APP_FQDN=
# URL da API do Proxmox VE — ex.: https://proxmox.exemplo.com:8006/ [OBRIGATÓRIA]
PROXMOX_URL=
# ID do API token de serviço do Proxmox — formato user@realm!nome [OBRIGATÓRIA]
PROXMOX_TOKEN_ID=
# Segredo do API token do Proxmox [OBRIGATÓRIA]
PROXMOX_TOKEN_SECRET=
# Senha da conta de bind do LDAP (admin do lldap) [OBRIGATÓRIA]
LDAP_BIND_PASSWORD=
# Segredo dos tokens de sessão — openssl rand -hex 32 [OBRIGATÓRIA]
JWT_SECRET=
# Tag da imagem no GHCR
APP_IMAGE_TAG=latest
# Marca exibida no topo do painel (canto superior esquerdo)
APP_BRAND=orquestrator4proxmox
# Desabilita a verificação TLS do Proxmox (true apenas para cert self-signed em dev)
PROXMOX_TLS_INSECURE=false
# Tag que marca (e revela) as VMs de cliente
PROXMOX_CLIENT_TAG=cliente
# Tags que ocultam VMs, mesmo com a tag cliente
PROXMOX_HIDDEN_TAGS=mgmt,infra
# Storage de destino do clone
PROXMOX_TARGET_STORAGE=local-zfs
# Endpoint LDAP
LDAP_URL=ldap://lldap_server:3890
# Base DN do diretório
LDAP_BASE_DN=dc=example,dc=com
# Conta de bind (admin do lldap)
LDAP_BIND_DN=uid=admin,ou=people,dc=example,dc=com
# Se preenchido, só membros deste grupo LDAP conseguem logar
LDAP_REQUIRED_GROUP=
# Duração da sessão
SESSION_TTL=8h
# Rede externa do Traefik
PROXY_NET=web
# Rede externa compartilhada do LDAP
LDAP_NET=ldap

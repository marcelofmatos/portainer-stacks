# Variáveis para subir a stack "chromadb".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: chroma.exemplo.com [OBRIGATÓRIA]
CHROMA_FQDN=

# Token de auth (opcional) — Se definido, exige Bearer token [OBRIGATÓRIA]
CHROMA_AUTH_TOKEN=

# Provider de auth — Para token: chromadb.auth.token_authn.TokenAuthenticationServerProvider [OBRIGATÓRIA]
CHROMA_AUTH_PROVIDER=

# ─────────── Opcionais (defaults abaixo) ───────────
# Rede do proxy
PROXY_NET=web

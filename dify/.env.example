# Variáveis para subir a stack "dify".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: dify.exemplo.com [OBRIGATÓRIA]
DIFY_FQDN=

# Secret key — openssl rand -base64 42 [OBRIGATÓRIA]
DIFY_SECRET_KEY=

# Senha do PostgreSQL — Senha do usuario do banco (segredo) [OBRIGATÓRIA]
DIFY_DB_PASSWORD=

# Sandbox API key — Chave compartilhada api/worker/sandbox [OBRIGATÓRIA]
DIFY_SANDBOX_API_KEY=

# ─────────── Opcionais (defaults abaixo) ───────────
# Host do PostgreSQL
DIFY_DB_HOST=postgres

# Banco
DIFY_DB_NAME=dify

# URL do Qdrant
DIFY_QDRANT_URL=http://qdrant:6333

# Tag das imagens
DIFY_IMAGE_TAG=latest

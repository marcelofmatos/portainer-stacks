# Variáveis para subir a stack "mongo-express".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: mongo.exemplo.com [OBRIGATÓRIA]
MONGOEXPRESS_FQDN=

# Senha do MongoDB — Senha do usuario do MongoDB (segredo) [OBRIGATÓRIA]
MONGOEXPRESS_MONGO_PASSWORD=

# Senha de login — Senha de login do Mongo Express (segredo) [OBRIGATÓRIA]
MONGOEXPRESS_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Usuario de login
MONGOEXPRESS_USERNAME=admin

# Usuario do MongoDB
MONGOEXPRESS_MONGO_USER=root

# Host do MongoDB
MONGOEXPRESS_MONGO_HOST=mongodb

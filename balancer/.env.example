# Variáveis para subir a stack "balancer".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio base — Dashboard fica em traefik.balancer.<DOMAIN> [OBRIGATÓRIA]
DOMAIN=

# E-mail Let's Encrypt — Contato para os certificados [OBRIGATÓRIA]
ACME_EMAIL=

# Basicauth do dashboard — Formato usuario:hash_bcrypt (htpasswd -nbB) [OBRIGATÓRIA]
HTTP_AUTH_BASIC=

# ─────────── Opcionais (defaults abaixo) ───────────
# Rede publica
PROXY_NET=web

# Nivel de log
TRAEFIK_LOG_LEVEL=WARN

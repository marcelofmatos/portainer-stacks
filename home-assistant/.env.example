# Variáveis para subir a stack "home-assistant".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: casa.exemplo.com [OBRIGATÓRIA]
HOMEASSISTANT_FQDN=

# ─────────── Opcionais (defaults abaixo) ───────────
# Fuso horario
TZ=America/Sao_Paulo

# Tag da imagem
HOMEASSISTANT_IMAGE_TAG=stable

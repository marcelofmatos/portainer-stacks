# Variáveis para subir a stack "espocrm".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: crm.exemplo.com [OBRIGATÓRIA]
ESPOCRM_FQDN=

# Senha do MariaDB — Senha do usuario do banco (segredo) [OBRIGATÓRIA]
ESPOCRM_DB_PASSWORD=

# Senha root do MariaDB — Obrigatoria: senha do usuario root do banco embarcado (segredo) [OBRIGATÓRIA]
ESPOCRM_DB_ROOT_PASSWORD=

# Senha do admin — Senha do admin criado no primeiro deploy (segredo) [OBRIGATÓRIA]
ESPOCRM_ADMIN_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Usuario admin
ESPOCRM_ADMIN_USERNAME=admin

# Host do MariaDB — Servico de banco embarcado nesta stack (deixe 'db'). So altere para usar um MariaDB externo.
ESPOCRM_DB_HOST=db

# Banco
ESPOCRM_DB_NAME=espocrm

# Usuario do MariaDB
ESPOCRM_DB_USER=espocrm

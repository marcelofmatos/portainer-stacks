# Variáveis para subir a stack "deep-research". Copie para .env: cp .env.example .env

# Domínio (FQDN) onde a UI fica exposta. Ex.: deep-research.exemplo.com [OBRIGATÓRIA]
DEEPRESEARCH_FQDN=
# Chave OpenAI usada pelo agente (https://platform.openai.com/api-keys) [OBRIGATÓRIA]
OPENAI_API_KEY=
# Chave Tavily para busca web (https://app.tavily.com/) [OBRIGATÓRIA]
TAVILY_API_KEY=
# Modelo OpenAI usado pelo agente
OPENAI_MODEL=gpt-5.2
# Tag da imagem no GHCR
DEEPRESEARCH_IMAGE_TAG=latest
# Rede externa do proxy (standalone: crie com "docker network create web")
PROXY_NET=web

# Variáveis para subir a stack "pgadmin4".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: pgadmin.exemplo.com [OBRIGATÓRIA]
PGADMIN_FQDN=

# E-mail do admin — Login do administrador [OBRIGATÓRIA]
PGADMIN_EMAIL=

# Senha do admin — Senha do administrador [OBRIGATÓRIA]
PGADMIN_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Rede do proxy
PROXY_NET=web

# Variáveis para subir a stack "twenty".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: twenty.exemplo.com [OBRIGATÓRIA]
TWENTY_FQDN=

# App secret — Segredo da aplicacao (openssl rand -base64 32) [OBRIGATÓRIA]
TWENTY_APP_SECRET=

# Senha do PostgreSQL — Senha do usuario do banco (segredo) [OBRIGATÓRIA]
TWENTY_DB_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Host do PostgreSQL — Servico de banco embarcado nesta stack (deixe 'db'). So altere para usar um Postgres externo.
TWENTY_DB_HOST=db

# Banco
TWENTY_DB_NAME=twenty

# Usuario do PostgreSQL
TWENTY_DB_USER=postgres

# URI do Redis
TWENTY_REDIS_URL=redis://redis:6379

# Tag da imagem
TWENTY_IMAGE_TAG=latest

# Variáveis para subir a stack "ligerosmart".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: suporte.exemplo.com [OBRIGATÓRIA]
LIGEROSMART_FQDN=

# Senha do banco — Senha do usuario do MariaDB [OBRIGATÓRIA]
LIGEROSMART_DB_PASSWORD=

# Senha root MariaDB — Senha root do MariaDB [OBRIGATÓRIA]
LIGEROSMART_DB_ROOT_PASSWORD=

# Nó do webserver (obrigatório) — Hostname do nó Swarm onde fixar o serviço (veja `docker node ls`) [OBRIGATÓRIA]
NODE_HOSTNAME_WEBSERVER=

# Nó do MariaDB (obrigatório) — Hostname do nó Swarm onde fixar o serviço (veja `docker node ls`) [OBRIGATÓRIA]
NODE_HOSTNAME_DATABASE=

# Nó do Elasticsearch (obrigatório) — Hostname do nó Swarm onde fixar o serviço (veja `docker node ls`) [OBRIGATÓRIA]
NODE_HOSTNAME_ELASTICSEARCH=

# Nó do Grafana (obrigatório) — Hostname do nó Swarm onde fixar o serviço (veja `docker node ls`) [OBRIGATÓRIA]
NODE_HOSTNAME_GRAFANA=

# ─────────── Opcionais (defaults abaixo) ───────────
# Idioma
LIGEROSMART_LANGUAGE=pt_BR

# Heap do Elasticsearch
ES_JAVA_OPTS=-Xms512m -Xmx512m

# Rede do proxy
PROXY_NET=web

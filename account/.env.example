# Variáveis para subir a stack "account".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio do LAM — Ex.: account.exemplo.com [OBRIGATÓRIA]
LAM_FQDN=

# Dominio do self-service-password — Ex.: senha.exemplo.com [OBRIGATÓRIA]
SSP_FQDN=

# Senha admin LDAP — Senha do cn=admin,dc=... [OBRIGATÓRIA]
LDAP_ADMIN_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Dominio LDAP — Vira dc=... (ex.: exemplo.com)
LDAP_DOMAIN=example.com

# Organizacao
LDAP_ORGANISATION=Example Org

# Docker config (config.inc.local.php)
SSP_CONFIG_NAME=account_ssp_config_v1

# Docker config (custom.css)
SSP_CSS_NAME=account_ssp_css_custom_v1

# Rede do proxy
PROXY_NET=web

# Rede compartilhada LDAP
LDAP_NET=ldap

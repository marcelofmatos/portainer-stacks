# Variáveis para subir a stack "docker-service-update".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: deploy.exemplo.com [OBRIGATÓRIA]
UPDATE_FQDN=

# Basicauth do webhook — Formato usuario:hash_bcrypt (htpasswd -nbB) [OBRIGATÓRIA]
UPDATE_AUTH_BASIC=

# ─────────── Opcionais (defaults abaixo) ───────────
# Tag da imagem
APP_IMAGE_TAG=latest

# Rede do proxy
PROXY_NET=web

# Variáveis para subir a stack "redirect".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio de origem — Ex.: antigo.exemplo.com [OBRIGATÓRIA]
REDIRECT_FQDN=

# URL de destino — Ex.: https://novo.exemplo.com [OBRIGATÓRIA]
REDIRECT_TARGET=

# ─────────── Opcionais (defaults abaixo) ───────────
# Tipo
REDIRECT_TYPE=redirect

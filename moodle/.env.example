# Variáveis para subir a stack "moodle".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: moodle.exemplo.com [OBRIGATÓRIA]
MOODLE_FQDN=

# Senha do banco — Senha do usuario do banco [OBRIGATÓRIA]
MOODLE_DB_PASSWORD=

# Senha admin Moodle — Senha do administrador [OBRIGATÓRIA]
MOODLE_ADMIN_PASSWORD=

# Senha root MariaDB — Senha root do MariaDB [OBRIGATÓRIA]
MARIADB_ROOT_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Usuario admin
MOODLE_ADMIN_USER=admin

# E-mail admin
MOODLE_ADMIN_EMAIL=admin@example.com

# Rede do proxy
PROXY_NET=web

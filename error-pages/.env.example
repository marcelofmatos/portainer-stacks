# Variáveis para subir a stack "error-pages".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio de preview (opcional) — Ex.: errors.exemplo.com [OBRIGATÓRIA]
ERRORPAGES_FQDN=

# ─────────── Opcionais (defaults abaixo) ───────────
# Template visual — ghost, l7-dark, matrix, etc.
ERRORPAGES_TEMPLATE=ghost

# Rede do proxy
PROXY_NET=web

# Variáveis para subir a stack "postgres-pgvector".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Senha do PostgreSQL — Senha do usuario do banco [OBRIGATÓRIA]
POSTGRES_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Banco padrao
POSTGRES_DB=vectordb

# Usuario do banco
POSTGRES_USER=postgres

# Tag pgvector
PGVECTOR_IMAGE_TAG=pg16

# Rede de dados
DATA_NET=data

# Variáveis para subir a stack "keycloak".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: auth.exemplo.com [OBRIGATÓRIA]
KEYCLOAK_FQDN=

# Senha do admin — Senha do admin bootstrap [OBRIGATÓRIA]
KEYCLOAK_ADMIN_PASSWORD=

# Senha do banco — Senha do PostgreSQL [OBRIGATÓRIA]
KEYCLOAK_DB_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Usuario admin
KEYCLOAK_ADMIN=admin

# Rede do proxy
PROXY_NET=web

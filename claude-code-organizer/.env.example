# Variáveis para subir a stack "claude-code-organizer".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: cco.exemplo.com [OBRIGATÓRIA]
CCO_FQDN=

# ─────────── Opcionais (defaults abaixo) ───────────
# Tag da imagem
CCO_IMAGE_TAG=latest

# Rede do proxy
PROXY_NET=web

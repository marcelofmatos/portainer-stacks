# Variáveis para subir a stack "stirlingpdf".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: pdf.exemplo.com [OBRIGATÓRIA]
STIRLING_FQDN=

# ─────────── Opcionais (defaults abaixo) ───────────
# Habilitar login
STIRLING_ENABLE_SECURITY=false

# Idiomas
STIRLING_LANGS=pt_BR,en_US

# Rede do proxy
PROXY_NET=web

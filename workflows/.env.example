# Variáveis para subir a stack "workflows".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: workflows.exemplo.com [OBRIGATÓRIA]
N8N_FQDN=

# Encryption key — openssl rand -hex 32 [OBRIGATÓRIA]
N8N_ENCRYPTION_KEY=

# Senha do banco — Senha do PostgreSQL [OBRIGATÓRIA]
N8N_DB_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Timezone
TZ=America/Sao_Paulo

# Rede do proxy
PROXY_NET=web

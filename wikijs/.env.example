# Variáveis para subir a stack "wikijs".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: wiki.exemplo.com [OBRIGATÓRIA]
WIKIJS_FQDN=

# Senha do banco — Senha do usuario do PostgreSQL (app e db) [OBRIGATÓRIA]
WIKIJS_DB_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Host do banco
WIKIJS_DB_HOST=db

# Banco
WIKIJS_DB_NAME=wikijs

# Usuario do banco
WIKIJS_DB_USER=wikijs

# Rede do proxy
PROXY_NET=web

# Rede de dados
DATA_NET=data

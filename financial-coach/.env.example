# Variáveis para subir a stack "financial-coach". Copie para .env: cp .env.example .env

# Domínio (FQDN) onde a UI fica exposta. Ex.: financial-coach.exemplo.com [OBRIGATÓRIA]
FINCOACH_FQDN=
# Chave Google/Gemini usada pelo agente ADK (https://makersuite.google.com/app/apikey) [OBRIGATÓRIA]
GOOGLE_API_KEY=
# Tag da imagem no GHCR
FINCOACH_IMAGE_TAG=latest
# Rede externa do proxy (standalone: crie com "docker network create web")
PROXY_NET=web

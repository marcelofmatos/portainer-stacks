# Variáveis para subir a stack "mongodb".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Senha do root — Senha do usuario root do MongoDB (segredo) [OBRIGATÓRIA]
MONGO_ROOT_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Usuario root
MONGO_ROOT_USERNAME=root

# Banco inicial
MONGO_DATABASE=appdb

# Tag da imagem
MONGO_IMAGE_TAG=7

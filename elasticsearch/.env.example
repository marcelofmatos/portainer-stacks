# Variáveis para subir a stack "elasticsearch".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Senha do elastic — Senha do usuario elastic (segredo) [OBRIGATÓRIA]
ELASTIC_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Heap da JVM
ELASTIC_JAVA_OPTS=-Xms512m -Xmx512m

# xpack security
ELASTIC_SECURITY=true

# Tag da imagem
ELASTIC_IMAGE_TAG=8.15.3

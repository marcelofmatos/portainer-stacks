# Variáveis para subir a stack "cloudflared".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Token do túnel — Cloudflare Zero Trust > Networks > Tunnels > token do conector (segredo) [OBRIGATÓRIA]
CLOUDFLARED_TUNNEL_TOKEN=

# ─────────── Opcionais (defaults abaixo) ───────────
# Tag da imagem
CLOUDFLARED_IMAGE_TAG=latest

# Variáveis para subir a stack "shadcn-generator". Copie para .env: cp .env.example .env

# Domínio (FQDN) onde a UI fica exposta. Ex.: shadcn.exemplo.com [OBRIGATÓRIA]
SHADCN_FQDN=
# Chave OpenAI usada pelo agente e pelo runtime CopilotKit (https://platform.openai.com/api-keys) [OBRIGATÓRIA]
OPENAI_API_KEY=
# Chave Tavily usada pelo agente para web search/extract/crawl (https://app.tavily.com/) [OBRIGATÓRIA]
TAVILY_API_KEY=
# Tag da imagem no GHCR
SHADCN_IMAGE_TAG=latest
# Rede externa do proxy (standalone: crie com "docker network create web")
PROXY_NET=web

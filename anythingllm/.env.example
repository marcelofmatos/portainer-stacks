# Variáveis para subir a stack "anythingllm".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: rag.exemplo.com [OBRIGATÓRIA]
ANYTHINGLLM_FQDN=

# JWT secret — Obrigatorio: segredo de sessao (openssl rand -hex 32) [OBRIGATÓRIA]
ANYTHINGLLM_JWT_SECRET=

# ─────────── Opcionais (defaults abaixo) ───────────
# Tag da imagem
ANYTHINGLLM_IMAGE_TAG=latest

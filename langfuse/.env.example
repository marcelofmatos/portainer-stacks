# Variáveis para subir a stack "langfuse".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: langfuse.exemplo.com [OBRIGATÓRIA]
LANGFUSE_FQDN=

# Senha do PostgreSQL — Senha do usuario do banco (segredo) [OBRIGATÓRIA]
LANGFUSE_DB_PASSWORD=

# NextAuth secret — openssl rand -base64 32 [OBRIGATÓRIA]
LANGFUSE_NEXTAUTH_SECRET=

# Salt — openssl rand -base64 32 [OBRIGATÓRIA]
LANGFUSE_SALT=

# ─────────── Opcionais (defaults abaixo) ───────────
# Host do PostgreSQL — Servico de banco embarcado nesta stack (deixe 'db'). So altere para usar um Postgres externo.
LANGFUSE_DB_HOST=db

# Banco
LANGFUSE_DB_NAME=langfuse

# Desabilitar signup
LANGFUSE_DISABLE_SIGNUP=true

# Tag da imagem
LANGFUSE_IMAGE_TAG=2

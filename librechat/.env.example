# Variáveis para subir a stack "librechat".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: librechat.exemplo.com [OBRIGATÓRIA]
LIBRECHAT_FQDN=

# Senha do MongoDB — Senha do usuario do MongoDB (segredo) [OBRIGATÓRIA]
LIBRECHAT_MONGO_PASSWORD=

# CREDS_KEY — 32 bytes hex (openssl rand -hex 32) [OBRIGATÓRIA]
LIBRECHAT_CREDS_KEY=

# CREDS_IV — 16 bytes hex (openssl rand -hex 16) [OBRIGATÓRIA]
LIBRECHAT_CREDS_IV=

# JWT secret — openssl rand -hex 32 [OBRIGATÓRIA]
LIBRECHAT_JWT_SECRET=

# JWT refresh secret — openssl rand -hex 32 [OBRIGATÓRIA]
LIBRECHAT_JWT_REFRESH_SECRET=

# Meili master key — openssl rand -hex 32 [OBRIGATÓRIA]
LIBRECHAT_MEILI_MASTER_KEY=

# Base OpenAI-compatible — Ex.: https://litellm.exemplo.com/v1 (opcional) [OBRIGATÓRIA]
LIBRECHAT_OPENAI_REVERSE_PROXY=

# ─────────── Opcionais (defaults abaixo) ───────────
# Permitir registro
LIBRECHAT_ALLOW_REGISTRATION=false

# Variáveis para subir a stack "typebot".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio do builder — Ex.: typebot.exemplo.com [OBRIGATÓRIA]
TYPEBOT_BUILDER_FQDN=

# Dominio do viewer — Ex.: bot.exemplo.com [OBRIGATÓRIA]
TYPEBOT_VIEWER_FQDN=

# Encryption secret — 32 chars (openssl rand -base64 24) [OBRIGATÓRIA]
TYPEBOT_ENCRYPTION_SECRET=

# Senha do PostgreSQL — Senha do usuario do banco (segredo) [OBRIGATÓRIA]
TYPEBOT_DB_PASSWORD=

# E-mail do admin — E-mail que vira admin no primeiro acesso [OBRIGATÓRIA]
TYPEBOT_ADMIN_EMAIL=

# ─────────── Opcionais (defaults abaixo) ───────────
# Host do PostgreSQL — Servico de banco embarcado nesta stack (deixe 'db'). So altere para usar um Postgres externo.
TYPEBOT_DB_HOST=db

# Banco
TYPEBOT_DB_NAME=typebot

# Usuario do PostgreSQL
TYPEBOT_DB_USER=postgres

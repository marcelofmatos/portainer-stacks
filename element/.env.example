# Variáveis para subir a stack "element".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio do homeserver (FQDN) — Identidade dos usuarios (@usuario:dominio) e host do Synapse. Ex.: matrix.exemplo.com [OBRIGATÓRIA]
MATRIX_SERVER_NAME=

# Dominio do Element Web (FQDN) — Onde o cliente web e publicado. Ex.: chat.exemplo.com [OBRIGATÓRIA]
ELEMENT_FQDN=

# Senha do PostgreSQL — Senha do banco embarcado do Synapse (segredo) [OBRIGATÓRIA]
MATRIX_DB_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Nome da marca (chat) — Nome exibido no titulo e na tela de boas-vindas do cliente. Ex.: Acme Chat
ELEMENT_BRAND=Chat

# Registro aberto na web — true para permitir auto-cadastro publico; false (recomendado) cria usuarios via CLI
SYNAPSE_ENABLE_REGISTRATION=false

# Enviar estatisticas anonimas — yes/no
SYNAPSE_REPORT_STATS=no

# Banco
SYNAPSE_DB_NAME=synapse

# Usuario do PostgreSQL
SYNAPSE_DB_USER=synapse

# Host do PostgreSQL — Servico de banco embarcado nesta stack (deixe 'db'). So altere para Postgres externo.
SYNAPSE_DB_HOST=db

# Tag da imagem Synapse
SYNAPSE_IMAGE_TAG=latest

# Tag da imagem Element (white-label) — Imagem custom ghcr.io/marcelofmatos/element (branding criado)
ELEMENT_IMAGE_TAG=latest

# Tag da imagem PostgreSQL
MATRIX_DB_IMAGE_TAG=16-alpine

# Rede do proxy
PROXY_NET=web

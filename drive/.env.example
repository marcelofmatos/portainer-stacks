# Variáveis para subir a stack "drive".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: drive.exemplo.com [OBRIGATÓRIA]
DRIVE_FQDN=

# Senha do admin — Senha do admin inicial do ownCloud [OBRIGATÓRIA]
OWNCLOUD_ADMIN_PASSWORD=

# Senha do banco — Senha do usuario MySQL do ownCloud [OBRIGATÓRIA]
OWNCLOUD_DB_PASSWORD=

# Senha root do MySQL — Senha root do MySQL [OBRIGATÓRIA]
MYSQL_ROOT_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Usuario admin
OWNCLOUD_ADMIN_USERNAME=admin

# Idioma padrao
OWNCLOUD_DEFAULT_LANGUAGE=pt_BR

# Limite de upload
OWNCLOUD_MAX_UPLOAD=100G

# Tag da imagem ownCloud
OWNCLOUD_IMAGE_TAG=10.15.0

# Rede do proxy
PROXY_NET=web

# Rede compartilhada LDAP
LDAP_NET=ldap

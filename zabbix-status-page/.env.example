# Variáveis para subir a stack "zabbix-status-page".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: status.exemplo.com [OBRIGATÓRIA]
STATUS_FQDN=

# URL do Zabbix — Base do Zabbix, ex.: https://zabbix.exemplo.com/zabbix/ (>= 6.4) [OBRIGATÓRIA]
ZABBIX_URL=

# Token da API do Zabbix — Token Bearer somente-leitura (segredo) [OBRIGATÓRIA]
ZABBIX_TOKEN=

# ─────────── Opcionais (defaults abaixo) ───────────
# Titulo exibido na pagina
PAGE_TITLE=Status

# Fuso horario (fecha o bucket diario do historico)
TZ=UTC

# Agregar/exibir status por host group (on/off)
ZABBIX_STATUS_BY_GROUPS=on

# Exibir incidentes em aberto (on/off)
ZABBIX_KNOWLEADS=on

# Incluir comentarios de acknowledge nos incidentes (on/off)
ZABBIX_KNOWLEADS_COMMENTS=on

# CSV de IDs de host groups a incluir (vazio = todos)
ZABBIX_GROUPS_IDS=

# CSV de IDs de hosts a incluir (vazio = todos)
ZABBIX_HOSTS_IDS=

# Severidade minima (0-5) considerada como problema
ZABBIX_MIN_SEVERITY=0

# Intervalo entre coletas no Zabbix (segundos)
POLL_INTERVAL_SECONDS=60

# Janela do historico de uptime (dias)
HISTORY_DAYS=90

# Tag da imagem
APP_IMAGE_TAG=latest

# Rede do proxy
PROXY_NET=web

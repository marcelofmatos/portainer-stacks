# Variáveis para subir a stack "grafana".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: grafana.exemplo.com [OBRIGATÓRIA]
GRAFANA_FQDN=

# Senha do admin — senha do usuario admin (segredo) [OBRIGATÓRIA]
GRAFANA_ADMIN_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Usuario admin
GRAFANA_ADMIN_USER=admin

# Plugins — lista separada por virgula (ex.: grafana-piechart-panel)
GRAFANA_PLUGINS=

# Tag da imagem
GRAFANA_IMAGE_TAG=latest

# Rede do proxy
PROXY_NET=web

# Rede de dados (datasources internos)
DATA_NET=data

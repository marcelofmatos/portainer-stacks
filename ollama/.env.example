# Variáveis para subir a stack "ollama".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (opcional) — Deixe vazio para nao expor publicamente [OBRIGATÓRIA]
OLLAMA_FQDN=

# ─────────── Opcionais (defaults abaixo) ───────────
# Keep-alive do modelo
OLLAMA_KEEP_ALIVE=5m

# Rede do proxy
PROXY_NET=web

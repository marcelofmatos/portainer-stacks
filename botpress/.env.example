# Variáveis para subir a stack "botpress".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: botpress.exemplo.com [OBRIGATÓRIA]
BOTPRESS_FQDN=

# Senha do PostgreSQL — Senha do usuario do banco (segredo) [OBRIGATÓRIA]
BOTPRESS_DB_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Host do PostgreSQL — Servico de banco embarcado nesta stack (deixe 'db'). So altere para usar um Postgres externo.
BOTPRESS_DB_HOST=db

# Banco
BOTPRESS_DB_NAME=botpress

# Usuario do PostgreSQL
BOTPRESS_DB_USER=postgres

# Variáveis para subir a stack "protonmail-bridge".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio da UI (FQDN) — Ex.: proton.exemplo.com [OBRIGATÓRIA]
PROTONMAIL_FQDN=

# Token da UI web — Token de acesso a UI (segredo; openssl rand -hex 32) [OBRIGATÓRIA]
PROTONMAIL_WEBUI_AUTH_TOKEN=

# ─────────── Opcionais (defaults abaixo) ───────────
# Tag da imagem
PROTONMAIL_IMAGE_TAG=latest

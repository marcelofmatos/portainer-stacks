# Variáveis para subir a stack "swarmprom".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio do Grafana — Ex.: grafana.exemplo.com [OBRIGATÓRIA]
SWARMPROM_GRAFANA_FQDN=

# Senha admin Grafana — Senha do admin do Grafana [OBRIGATÓRIA]
GRAFANA_ADMIN_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Usuario admin Grafana
GRAFANA_ADMIN_USER=admin

# Retencao Prometheus
PROMETHEUS_RETENTION=15d

# Rede do proxy
PROXY_NET=web

# Variáveis para subir a stack "qdrant".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: qdrant.exemplo.com [OBRIGATÓRIA]
QDRANT_FQDN=

# API key — Obrigatoria: exige o header api-key (a stack e exposta via Traefik) [OBRIGATÓRIA]
QDRANT_API_KEY=

# ─────────── Opcionais (defaults abaixo) ───────────
# Tag da imagem
QDRANT_IMAGE_TAG=latest

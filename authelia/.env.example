# Variáveis para subir a stack "authelia".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio do portal — Ex.: auth.exemplo.com [OBRIGATÓRIA]
AUTHELIA_FQDN=

# JWT secret — Segredo para assinar JWTs [OBRIGATÓRIA]
AUTHELIA_JWT_SECRET=

# Session secret — Segredo das sessoes [OBRIGATÓRIA]
AUTHELIA_SESSION_SECRET=

# Storage key — Chave de storage (min. 20 chars) [OBRIGATÓRIA]
AUTHELIA_STORAGE_ENCRYPTION_KEY=

# ─────────── Opcionais (defaults abaixo) ───────────
# Docker config
AUTHELIA_CONFIG_NAME=authelia_config_v1

# Rede do proxy
PROXY_NET=web

# Variáveis para subir a stack "searxng".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: busca.exemplo.com [OBRIGATÓRIA]
SEARXNG_FQDN=

# Secret — openssl rand -hex 32 [OBRIGATÓRIA]
SEARXNG_SECRET=

# URL do Redis — Ex.: redis://redis:6379/4 (opcional) [OBRIGATÓRIA]
SEARXNG_REDIS_URL=

# ─────────── Opcionais (defaults abaixo) ───────────
# Tag da imagem
SEARXNG_IMAGE_TAG=latest

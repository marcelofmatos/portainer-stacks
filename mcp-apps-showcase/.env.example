# Variáveis para subir a stack "mcp-apps-showcase". Copie para .env: cp .env.example .env

# Domínio (FQDN) onde a UI fica exposta. Ex.: mcp-apps.exemplo.com [OBRIGATÓRIA]
MCPAPPS_FQDN=
# Chave OpenAI usada pelo CopilotKit runtime (https://platform.openai.com/api-keys) [OBRIGATÓRIA]
OPENAI_API_KEY=
# Tag da imagem no GHCR
MCPAPPS_IMAGE_TAG=latest
# Rede externa do proxy (standalone: crie com "docker network create web")
PROXY_NET=web

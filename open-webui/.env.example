# Variáveis para subir a stack "open-webui".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: chat.exemplo.com [OBRIGATÓRIA]
OPENWEBUI_FQDN=

# Secret key — Sessao (openssl rand -hex 32) [OBRIGATÓRIA]
OPENWEBUI_SECRET_KEY=

# URL do Ollama — Ex.: https://ollama.exemplo.com [OBRIGATÓRIA]
OPENWEBUI_OLLAMA_URL=

# Base OpenAI-compatible — Ex.: https://litellm.exemplo.com/v1 [OBRIGATÓRIA]
OPENWEBUI_OPENAI_BASE_URL=

# Chave OpenAI/litellm — Chave do endpoint (opcional) [OBRIGATÓRIA]
OPENWEBUI_OPENAI_API_KEY=

# ─────────── Opcionais (defaults abaixo) ───────────
# Tag da imagem
OPENWEBUI_IMAGE_TAG=main

# Variáveis para subir a stack "mcp-app-builder". Copie para .env: cp .env.example .env

# Domínio (FQDN) onde a UI fica exposta. Ex.: mcp-app-builder.exemplo.com [OBRIGATÓRIA]
MCPBUILDER_FQDN=
# Chave OpenAI usada pelo chat/agente Mastra (https://platform.openai.com/api-keys) [OBRIGATÓRIA]
OPENAI_API_KEY=
# Chave E2B para provisionar sandboxes novos em runtime (https://e2b.dev/dashboard)
# [OPCIONAL] — vazio funciona com MCP servers pré-conectados (default Excalidraw)
E2B_API_KEY=
# Tag da imagem no GHCR
MCPBUILDER_IMAGE_TAG=latest
# Rede externa do proxy (standalone: crie com "docker network create web")
PROXY_NET=web

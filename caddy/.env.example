# Variáveis para subir a stack "caddy".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Opcionais (defaults abaixo) ───────────
# Rede (ingress) — Rede por onde o Caddy alcanca os alvos (CADDY_INGRESS_NETWORKS)
PROXY_NET=web

# Tag da imagem
CADDY_IMAGE_TAG=2.9-alpine

# Endpoint ACME — Troque pelo staging do Let's Encrypt durante testes
CADDY_ACME_CA=https://acme-v02.api.letsencrypt.org/directory

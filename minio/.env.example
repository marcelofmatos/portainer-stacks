# Variáveis para subir a stack "minio".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio API S3 — Ex.: s3.exemplo.com [OBRIGATÓRIA]
MINIO_S3_FQDN=

# Dominio do console — Ex.: minio.exemplo.com [OBRIGATÓRIA]
MINIO_CONSOLE_FQDN=

# Usuario root — Usuario admin inicial [OBRIGATÓRIA]
MINIO_ROOT_USER=

# Senha root — Senha do root (min. 8 chars) [OBRIGATÓRIA]
MINIO_ROOT_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Rede do proxy
PROXY_NET=web

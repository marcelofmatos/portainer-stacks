# Variáveis para subir a stack "evolution-api".
# Copie para .env e preencha as OBRIGATÓRIAS:  cp .env.example .env
# (No Portainer App Template, esses valores são pedidos no formulário.)

# ─────────── Obrigatórias ───────────
# Dominio (FQDN) — Ex.: evolution.exemplo.com [OBRIGATÓRIA]
EVOLUTION_FQDN=

# API key — Chave global de autenticacao da API [OBRIGATÓRIA]
EVOLUTION_API_KEY=

# Senha do PostgreSQL — Senha do usuario do banco compartilhado [OBRIGATÓRIA]
EVOLUTION_DB_PASSWORD=

# ─────────── Opcionais (defaults abaixo) ───────────
# Host do PostgreSQL — Servico de banco embarcado nesta stack (deixe 'db'). So altere para usar um Postgres externo.
EVOLUTION_DB_HOST=db

# Banco
EVOLUTION_DB_NAME=evolution

# URI do Redis
EVOLUTION_REDIS_URI=redis://redis:6379/6

# Rede do proxy
PROXY_NET=web

# Rede de dados
DATA_NET=data
